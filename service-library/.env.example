# Variables de entorno del Servicio Library (Sprint 1)
# Copiar este archivo a .env y ajustar los valores segun el entorno.
# NO guardar secretos reales en el repositorio.

# Puerto del servicio (contrato congelado: 4001)
PORT=4001

# Cadena de conexion a MongoDB
URI_MONGO=mongodb://localhost:27017/biblioteca_library

# Entorno de ejecucion: development | production
NODE_ENV=development

# Validacion de JWT emitido por Auth (Sprint 2). Deben coincidir con los valores de Auth.
JWT_SECRET=replace_with_a_secure_secret
JWT_ISSUER=biblioteca-auth
JWT_AUDIENCE=biblioteca-services
