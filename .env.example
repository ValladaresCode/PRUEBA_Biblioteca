# Referencia de variables por servicio (sin secretos reales).
# Cada servicio usa su propio archivo .env dentro de su carpeta.

# --- service-auth (.env en service-auth/) — PostgreSQL + Sequelize ---
# PORT=4000
# DATABASE_URL=postgresql://postgres:password@localhost:5432/biblioteca_auth
# JWT_SECRET=replace_with_a_secure_secret
# JWT_ISSUER=biblioteca-auth
# JWT_AUDIENCE=biblioteca-services
# JWT_EXPIRES_IN=2h
# FRONTEND_URL=http://localhost:5173
# NODE_ENV=development

# --- service-library (.env en service-library/) ---
# PORT=4001
# URI_MONGO=mongodb://localhost:27017/biblioteca_library
# JWT_SECRET=replace_with_a_secure_secret
# JWT_ISSUER=biblioteca-auth
# JWT_AUDIENCE=biblioteca-services

# --- service-statistics (.env en service-statistics/) ---
# PORT=4002
# SERVICE_LIBRARY_URL=http://localhost:4001
# JWT_SECRET=replace_with_a_secure_secret
# JWT_ISSUER=biblioteca-auth
# JWT_AUDIENCE=biblioteca-services

# Nota (Sprint 2): JWT_SECRET, JWT_ISSUER y JWT_AUDIENCE deben tener el MISMO valor
# en service-auth, service-library y service-statistics, ya que Auth emite el JWT
# y Library/Statistics solo lo validan. No copiar valores reales en este archivo.

# --- frontend (.env en frontend/) ---
# VITE_AUTH_API_URL=http://localhost:4000/api/v1
# VITE_LIBRARY_API_URL=http://localhost:4001/api/v1
# VITE_STATISTICS_API_URL=http://localhost:4002/api/v1
